#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run lint-staged
pnpm lint-staged

# Run form-specific tests if FORM environment variable is set
if [ ! -z "$FORM" ]; then
  echo "Running tests for form: $FORM"
  pnpm run test:form -- $FORM
  if [ $? -ne 0 ]; then
    echo "❌ Form tests failed for $FORM. Commit aborted."
    exit 1
  fi
fi

# Run lint fix
pnpm run lint:fix
if [ $? -ne 0 ]; then
  echo "❌ Lint fix failed. Commit aborted."
  exit 1
fi

echo "✅ Pre-commit checks passed"