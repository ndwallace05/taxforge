{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES6"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@taxforge/ui": ["./packages/ui/src"],
      "@taxforge/ui/*": ["./packages/ui/src/*"],
      "@taxforge/irs-data": ["./packages/irs-data/src"],
      "@taxforge/irs-data/*": ["./packages/irs-data/src/*"],
      "@taxforge/tests": ["./packages/tests/src"],
      "@taxforge/tests/*": ["./packages/tests/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "**/dist",
    "**/.next",
    "**/build"
  ],
  "references": [
    {
      "path": "./packages/ui"
    },
    {
      "path": "./packages/irs-data"
    },
    {
      "path": "./apps/taxforge-web"
    }
  ]
}
