/* Form1040 Component Styles with myTAXprepoffice branding */

.form1040Container {
  max-width: 1200px;
  margin: 0 auto;
  background: white;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  border-radius: 8px;
}

/* myTAXprepoffice Blue Pills */
.stepPill {
  display: inline-flex;
  align-items: center;
  padding: 0.5rem 1rem;
  background: #3b82f6;
  color: white;
  border-radius: 9999px;
  font-size: 0.875rem;
  font-weight: 500;
  margin-right: 0.5rem;
}

.stepPill.active {
  background: #1d4ed8;
}

.stepPill.completed {
  background: #10b981;
}

/* Zebra Striped Tables */
.zebraTable {
  width: 100%;
  border-collapse: collapse;
}

.zebraTable tr:nth-child(even) {
  background-color: #f8fafc;
}

.zebraTable tr:nth-child(odd) {
  background-color: white;
}

.zebraTable th,
.zebraTable td {
  padding: 0.75rem;
  text-align: left;
  border-bottom: 1px solid #e2e8f0;
}

.zebraTable th {
  background-color: #3b82f6;
  color: white;
  font-weight: 600;
}

/* Sidebar Styling */
.calculationSidebar {
  background: #f1f5f9;
  border: 1px solid #cbd5e1;
  border-radius: 8px;
  padding: 1.5rem;
  position: sticky;
  top: 1.5rem;
}

.calculationSidebar h3 {
  color: #1e40af;
  font-weight: 600;
  margin-bottom: 1rem;
  border-bottom: 2px solid #3b82f6;
  padding-bottom: 0.5rem;
}

/* Form Input Styling */
.formInput {
  width: 100%;
  padding: 0.75rem;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 0.875rem;
  transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
}

.formInput:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.formInput.error {
  border-color: #ef4444;
}

/* Button Styling */
.primaryButton {
  background: #3b82f6;
  color: white;
  padding: 0.75rem 1.5rem;
  border: none;
  border-radius: 6px;
  font-weight: 500;
  cursor: pointer;
  transition: background-color 0.15s ease-in-out;
}

.primaryButton:hover {
  background: #2563eb;
}

.primaryButton:disabled {
  background: #9ca3af;
  cursor: not-allowed;
}

.secondaryButton {
  background: white;
  color: #374151;
  padding: 0.75rem 1.5rem;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-weight: 500;
  cursor: pointer;
  transition: background-color 0.15s ease-in-out;
}

.secondaryButton:hover {
  background: #f9fafb;
}

/* Responsive Design */
@media (max-width: 768px) {
  .form1040Container {
    margin: 0 1rem;
    border-radius: 0;
  }
  
  .calculationSidebar {
    position: static;
    margin-top: 2rem;
  }
  
  .stepPill {
    font-size: 0.75rem;
    padding: 0.375rem 0.75rem;
  }
}

/* Accessibility */
@media (prefers-reduced-motion: reduce) {
  .formInput,
  .primaryButton,
  .secondaryButton {
    transition: none;
  }
}

/* High contrast mode */
@media (prefers-contrast: high) {
  .stepPill {
    border: 2px solid currentColor;
  }
  
  .formInput {
    border-width: 2px;
  }
  
  .calculationSidebar {
    border-width: 2px;
  }
}