{
  "formId": "1040",
  "formTitle": "U.S. Individual Income Tax Return",
  "taxYear": 2024,
  "version": "1.0.0",
  "description": "Form 1040 is used by U.S. citizens and residents to file their annual income tax return",
  "fields": {
    "1040_filing_status": {
      "label": "Filing Status",
      "type": "select",
      "required": true,
      "options": [
        { "value": "single", "label": "Single" },
        {
          "value": "married_filing_jointly",
          "label": "Married filing jointly"
        },
        {
          "value": "married_filing_separately",
          "label": "Married filing separately"
        },
        { "value": "head_of_household", "label": "Head of household" },
        {
          "value": "qualifying_surviving_spouse",
          "label": "Qualifying surviving spouse"
        }
      ],
      "validation": {
        "required": true
      },
      "line": "filing_status"
    },
    "1040_first_name": {
      "label": "First name",
      "type": "text",
      "required": true,
      "validation": {
        "required": true,
        "maxLength": 35
      },
      "line": "first_name"
    },
    "1040_last_name": {
      "label": "Last name",
      "type": "text",
      "required": true,
      "validation": {
        "required": true,
        "maxLength": 35
      },
      "line": "last_name"
    },
    "1040_ssn": {
      "label": "Social Security Number",
      "type": "ssn",
      "required": true,
      "validation": {
        "required": true,
        "pattern": "^\\d{3}-\\d{2}-\\d{4}$"
      },
      "line": "ssn",
      "encrypted": true
    },
    "1040_spouse_first_name": {
      "label": "Spouse's first name",
      "type": "text",
      "required": false,
      "validation": {
        "maxLength": 35
      },
      "line": "spouse_first_name",
      "conditionalVisibility": {
        "field": "1040_filing_status",
        "values": ["married_filing_jointly", "married_filing_separately"]
      }
    },
    "1040_spouse_last_name": {
      "label": "Spouse's last name",
      "type": "text",
      "required": false,
      "validation": {
        "maxLength": 35
      },
      "line": "spouse_last_name",
      "conditionalVisibility": {
        "field": "1040_filing_status",
        "values": ["married_filing_jointly", "married_filing_separately"]
      }
    },
    "1040_spouse_ssn": {
      "label": "Spouse's Social Security Number",
      "type": "ssn",
      "required": false,
      "validation": {
        "pattern": "^\\d{3}-\\d{2}-\\d{4}$"
      },
      "line": "spouse_ssn",
      "encrypted": true,
      "conditionalVisibility": {
        "field": "1040_filing_status",
        "values": ["married_filing_jointly", "married_filing_separately"]
      }
    },
    "1040_address": {
      "label": "Home address",
      "type": "text",
      "required": true,
      "validation": {
        "required": true,
        "maxLength": 35
      },
      "line": "address"
    },
    "1040_city_state_zip": {
      "label": "City, state, and ZIP code",
      "type": "text",
      "required": true,
      "validation": {
        "required": true,
        "maxLength": 35
      },
      "line": "city_state_zip"
    },
    "1040_line_1a": {
      "label": "Wages, salaries, tips, etc.",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "1a",
      "calculation": {
        "source": "w2_wages_total"
      }
    },
    "1040_line_1b": {
      "label": "Household employee wages not reported on Form(s) W-2",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "1b"
    },
    "1040_line_1c": {
      "label": "Tip income not reported to employer",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "1c"
    },
    "1040_line_1d": {
      "label": "Nontaxable combat pay election",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "1d"
    },
    "1040_line_1e": {
      "label": "Add lines 1a through 1d",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "1e",
      "calculation": {
        "formula": "1040_line_1a + 1040_line_1b + 1040_line_1c + 1040_line_1d"
      }
    },
    "1040_line_2a": {
      "label": "Tax-exempt interest",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "2a"
    },
    "1040_line_2b": {
      "label": "Taxable interest",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "2b"
    },
    "1040_line_3a": {
      "label": "Qualified dividends",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "3a"
    },
    "1040_line_3b": {
      "label": "Ordinary dividends",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "3b"
    },
    "1040_line_4a": {
      "label": "IRA distributions - Total amount",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "4a"
    },
    "1040_line_4b": {
      "label": "IRA distributions - Taxable amount",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "4b"
    },
    "1040_line_5a": {
      "label": "Pensions and annuities - Total amount",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "5a"
    },
    "1040_line_5b": {
      "label": "Pensions and annuities - Taxable amount",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "5b"
    },
    "1040_line_6a": {
      "label": "Social security benefits - Total amount",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "6a"
    },
    "1040_line_6b": {
      "label": "Social security benefits - Taxable amount",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "6b"
    },
    "1040_line_7": {
      "label": "Capital gain or (loss)",
      "type": "currency",
      "required": false,
      "line": "7",
      "calculation": {
        "source": "schedule_d_line_21"
      }
    },
    "1040_line_8": {
      "label": "Additional income from Schedule 1, line 10",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "8",
      "calculation": {
        "source": "schedule_1_line_10"
      }
    },
    "1040_line_9": {
      "label": "Add lines 1e, 2b, 3b, 4b, 5b, 6b, 7, and 8. This is your total income",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "9",
      "calculation": {
        "formula": "1040_line_1e + 1040_line_2b + 1040_line_3b + 1040_line_4b + 1040_line_5b + 1040_line_6b + 1040_line_7 + 1040_line_8"
      }
    },
    "1040_line_10": {
      "label": "Adjustments to income from Schedule 1, line 26",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "10",
      "calculation": {
        "source": "schedule_1_line_26"
      }
    },
    "1040_line_11": {
      "label": "Subtract line 10 from line 9. This is your adjusted gross income",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "11",
      "calculation": {
        "formula": "1040_line_9 - 1040_line_10"
      }
    },
    "1040_line_12": {
      "label": "Standard deduction or itemized deductions",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "12",
      "calculation": {
        "formula": "max(standard_deduction, schedule_a_total)"
      }
    },
    "1040_line_13": {
      "label": "Qualified business income deduction",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "13"
    },
    "1040_line_14": {
      "label": "Add lines 12 and 13",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "14",
      "calculation": {
        "formula": "1040_line_12 + 1040_line_13"
      }
    },
    "1040_line_15": {
      "label": "Subtract line 14 from line 11. This is your taxable income",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "15",
      "calculation": {
        "formula": "max(0, 1040_line_11 - 1040_line_14)"
      }
    },
    "1040_line_16": {
      "label": "Tax",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "16",
      "calculation": {
        "formula": "calculate_tax(1040_line_15, 1040_filing_status)"
      }
    },
    "1040_line_17": {
      "label": "Amount from Schedule 2, line 3",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "17",
      "calculation": {
        "source": "schedule_2_line_3"
      }
    },
    "1040_line_18": {
      "label": "Add lines 16 and 17",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "18",
      "calculation": {
        "formula": "1040_line_16 + 1040_line_17"
      }
    },
    "1040_line_19": {
      "label": "Child tax credit and credit for other dependents from Schedule 3, line 8",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "19",
      "calculation": {
        "source": "schedule_3_line_8"
      }
    },
    "1040_line_20": {
      "label": "Amount from Schedule 3, line 15",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "20",
      "calculation": {
        "source": "schedule_3_line_15"
      }
    },
    "1040_line_21": {
      "label": "Add lines 19 and 20",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "21",
      "calculation": {
        "formula": "1040_line_19 + 1040_line_20"
      }
    },
    "1040_line_22": {
      "label": "Subtract line 21 from line 18. If zero or less, enter -0-",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "22",
      "calculation": {
        "formula": "max(0, 1040_line_18 - 1040_line_21)"
      }
    },
    "1040_line_23": {
      "label": "Other taxes, including self-employment tax, from Schedule 2, line 21",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "23",
      "calculation": {
        "source": "schedule_2_line_21"
      }
    },
    "1040_line_24": {
      "label": "Add lines 22 and 23. This is your total tax",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "24",
      "calculation": {
        "formula": "1040_line_22 + 1040_line_23"
      }
    },
    "1040_line_25a": {
      "label": "Federal income tax withheld",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "25a",
      "calculation": {
        "source": "w2_federal_withholding_total"
      }
    },
    "1040_line_25b": {
      "label": "2024 estimated tax payments and amount applied from 2023 return",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "25b"
    },
    "1040_line_25c": {
      "label": "Earned income credit (EIC)",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "25c"
    },
    "1040_line_25d": {
      "label": "Additional child tax credit from Schedule 3, line 16",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "25d",
      "calculation": {
        "source": "schedule_3_line_16"
      }
    },
    "1040_line_26": {
      "label": "American opportunity credit from Form 8863, line 8",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "26"
    },
    "1040_line_27": {
      "label": "Reserved for future use",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "27"
    },
    "1040_line_28": {
      "label": "Amount from Schedule 3, line 17",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "28",
      "calculation": {
        "source": "schedule_3_line_17"
      }
    },
    "1040_line_29": {
      "label": "Add lines 25a through 25d and lines 26, 27, and 28. These are your total payments",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "29",
      "calculation": {
        "formula": "1040_line_25a + 1040_line_25b + 1040_line_25c + 1040_line_25d + 1040_line_26 + 1040_line_27 + 1040_line_28"
      }
    },
    "1040_line_30": {
      "label": "If line 29 is more than line 24, subtract line 24 from line 29. This is the amount you overpaid",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "30",
      "calculation": {
        "formula": "max(0, 1040_line_29 - 1040_line_24)"
      }
    },
    "1040_line_31": {
      "label": "Amount of line 30 you want refunded to you",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0,
        "max": "1040_line_30"
      },
      "line": "31"
    },
    "1040_line_32": {
      "label": "Amount of line 30 you want applied to your 2025 estimated tax",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "32"
    },
    "1040_line_33": {
      "label": "Amount you owe",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "33",
      "calculation": {
        "formula": "max(0, 1040_line_24 - 1040_line_29)"
      }
    },
    "1040_line_34": {
      "label": "Estimated tax penalty",
      "type": "currency",
      "required": false,
      "validation": {
        "min": 0
      },
      "line": "34"
    }
  },
  "metadata": {
    "pdfUrl": "https://www.irs.gov/pub/irs-pdf/f1040.pdf",
    "instructionsUrl": "https://www.irs.gov/instructions/i1040gi",
    "mefSchemaUrl": "https://www.irs.gov/e-file-providers/modernized-e-file-mef-schemas-and-business-rules",
    "totalPages": 2,
    "totalLines": 34,
    "schedules": [
      "Schedule 1",
      "Schedule 2",
      "Schedule 3",
      "Schedule A",
      "Schedule B",
      "Schedule C",
      "Schedule D",
      "Schedule E"
    ]
  }
}
